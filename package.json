{
  "name": "moodle-teacher-hub",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "start": "node scripts/maintenance/fix-lti-routing-redirect-cache.cjs && node scripts/maintenance/add-lti13-readiness.cjs && node --check src/server.js && node src/server.js",
    "check": "node scripts/maintenance/fix-lti-routing-redirect-cache.cjs && node scripts/maintenance/add-lti13-readiness.cjs && node --check src/server.js",
    "dev:server": "node scripts/maintenance/fix-lti-routing-redirect-cache.cjs && node scripts/maintenance/add-lti13-readiness.cjs && node --check src/server.js && node src/server.js",
    "build": "node scripts/maintenance/fix-lti-routing-redirect-cache.cjs && node scripts/maintenance/add-lti13-readiness.cjs && node --check src/server.js && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --pretty false",
    "doctor": "node scripts/checks/repo-doctor.cjs",
    "audit:moodle-automation": "node scripts/checks/moodle-automation-readiness-audit.cjs",
    "validate:lti:live": "node scripts/checks/validate-lti-live.cjs",
    "validate:teacher-release:live": "node scripts/checks/teacher-release-live-gate.cjs",
    "validate:imports:live": "node scripts/checks/final-import-readiness.cjs",
    "validate:finish:live": "node scripts/checks/final-import-readiness.cjs && node scripts/checks/teacher-release-live-gate.cjs",
    "diagnose:pgrst205:live": "node scripts/checks/pgrst205-import-schema-diagnose.cjs",
    "validate:gradebook:live": "node scripts/checks/gradebook-preflight-live.cjs",
    "validate:gradebook:file": "node scripts/checks/gradebook-real-file-readiness.cjs",
    "validate:gradebook-ui:live": "node scripts/checks/gradebook-preflight-ui-live.cjs",
    "validate:wide-gradebook-ui:live": "node scripts/checks/wide-gradebook-import-ui-live.cjs",
    "validate:logs-ui:live": "node scripts/checks/logs-import-ui-live.cjs",
    "validate:capability-center:live": "node scripts/checks/dynamic-capability-center-live.cjs",
    "validate:moodle:static": "npm run audit:moodle-automation && npm run audit:auto-extraction-source-router && npm run audit:multi-teacher-isolation-evidence && npm run audit:supabase-rls-isolation-readiness",
    "validate:moodle:live": "npm run validate:lti:live && npm run validate:imports:live && npm run validate:teacher-release:live",
    "validate:moodle:all": "npm run validate:moodle:static && npm run validate:moodle:live",
    "audit:multi-teacher-safety": "node scripts/checks/no-hardcoded-course-teacher.cjs",
    "audit:deep-launch-context": "node scripts/checks/deep-launch-context-audit.cjs",
    "audit:lti-probes": "node scripts/checks/dynamic-lti-probes-sanity.cjs",
    "audit:moodle-webservices-readiness": "node scripts/checks/moodle-webservices-readiness.cjs",
    "audit:teacher-date-format": "node scripts/checks/teacher-date-format-audit.cjs",
    "audit:automation-capabilities": "node scripts/checks/automation-capabilities-audit.cjs",
    "audit:automation-capability-contract": "node scripts/checks/automation-capability-contract-audit.cjs",
    "audit:automation-evidence-log": "node scripts/checks/automation-evidence-log-audit.cjs",
    "audit:auto-extraction-source-router": "node scripts/checks/auto-extraction-source-router-audit.cjs",
    "audit:multi-teacher-isolation-evidence": "node scripts/checks/multi-teacher-isolation-evidence-audit.cjs",
    "audit:supabase-rls-isolation-readiness": "node scripts/checks/supabase-rls-isolation-readiness-audit.cjs"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/supabase-js": "^2.104.1",
    "@tanstack/react-query": "^5.83.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "lucide-react": "^0.462.0",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
