# Server runtime
PORT=3000
APP_BASE_URL=http://127.0.0.1:3000
SESSION_SECRET=replace-with-long-random-secret

# LTI 1.1 configuration
LTI11_KEY=replace-with-real-key
LTI11_SECRET=replace-with-real-secret
LTI_LAUNCH_URL=
LTI_SESSION_TTL_HOURS=8

# Moodle Web Services — leave empty/disabled until a real token is verified
MOODLE_BASE_URL=https://your-moodle.example.com
MOODLE_WS_TOKEN=
MOODLE_WS_SERVICE_NAME=teacher_hub_service
MOODLE_WS_ENABLED=false

# Supabase public frontend values from Lovable/Vite
# The real local .env may contain the actual values, but this template must not contain secrets.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase server-side only values — never expose in frontend
SUPABASE_SERVICE_ROLE_KEY=
