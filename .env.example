# Moodle Teacher Hub environment example
# Do not commit real secrets.

# Public URL used by Moodle to calculate the LTI signature base string.
# Localtunnel example:
# APP_BASE_URL=https://your-localtunnel-url.loca.lt
APP_BASE_URL=

# Supabase public frontend configuration.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase key. Never expose in frontend or GitHub.
SUPABASE_SERVICE_ROLE_KEY=

# Moodle LTI 1.0/1.1 settings.
LTI_CONSUMER_KEY=yaniv-lti-tool
LTI_SHARED_SECRET=

# Optional local testing only.
COOKIE_SECURE=false
LTI_ALLOW_OLD_TIMESTAMP=false
